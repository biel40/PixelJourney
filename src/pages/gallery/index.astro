---
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGalleryPhotos } from '../../lib/gallery';

const photos = await getGalleryPhotos();

const largeImages = await Promise.all(
  photos.map((photo) =>
    getImage({ src: photo.src, width: 1600, format: 'webp' }),
  ),
);
---

<BaseLayout
  title="Galería"
  description="Colección de fotografías móviles capturadas en el día a día."
>
  <main class="relative mx-auto max-w-6xl px-6 py-16">
    <div
      class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-115 overflow-hidden"
      aria-hidden="true"
    >
      <div class="gallery-glow"></div>
    </div>

    <header class="mb-12 text-center">
      <a
        href="/"
        class="reveal mb-8 inline-flex items-center gap-2 text-sm text-neutral-400 hover:text-white transition-colors"
        style="animation-delay: 60ms"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
        </svg>
        Inicio
      </a>
      <p
        class="reveal text-xs font-mono tracking-[0.3em] uppercase text-neutral-500 flex items-center justify-center gap-3"
        style="animation-delay: 140ms"
      >
        <span class="inline-block h-px w-8 bg-neutral-700"></span>
        Galería interactiva
        <span class="inline-block h-px w-8 bg-neutral-700"></span>
      </p>
      <h1
        class="reveal mt-2 text-4xl font-bold tracking-tight"
        style="animation-delay: 220ms"
        transition:name="page-title"
      >
        <span class="title-gradient">Las mejores fotografías</span>
      </h1>
      <p
        class="reveal mt-3 text-sm text-neutral-400"
        style="animation-delay: 300ms"
      >
        {photos.length} fotografías
      </p>
    </header>

    {
      photos.length === 0 ? (
        <p class="text-center text-neutral-500">
          Aún no hay fotografías disponibles.
        </p>
      ) : (
        <div class="columns-1 gap-4 sm:columns-2 lg:columns-3 *:mb-4">
          {photos.map((photo, index) => (
            <figure
              class="photo-reveal break-inside-avoid"
              style={`transition-delay: ${(index % 6) * 70}ms`}
            >
              <button
                type="button"
                class="group block w-full cursor-zoom-in overflow-hidden rounded-lg"
                data-lightbox-trigger
                data-large={largeImages[index].src}
                data-alt={photo.alt}
                aria-label={`Ampliar: ${photo.alt}`}
              >
                <Image
                  src={photo.src}
                  alt={photo.alt}
                  widths={[320, 640, 960]}
                  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                  loading={index < 6 ? 'eager' : 'lazy'}
                  decoding="async"
                  class="w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
                />
              </button>
            </figure>
          ))}
        </div>
      )
    }
  </main>

  <dialog
    id="lightbox"
    class="m-auto max-h-[90vh] max-w-[92vw] bg-transparent p-0 backdrop:bg-black/80 backdrop:backdrop-blur-sm"
  >
    <button
      type="button"
      id="lightbox-close"
      class="absolute right-4 top-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-black/50 text-white transition-colors hover:bg-black/70"
      aria-label="Cerrar"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
      </svg>
    </button>
    <img
      id="lightbox-img"
      src=""
      alt=""
      class="max-h-[90vh] max-w-[92vw] rounded-lg object-contain"
    />
  </dialog>
</BaseLayout>

<style>
  /* Estilos exclusivos de la galería. Las primitivas compartidas
     (.reveal, .title-gradient) viven en src/styles/global.css. */

  /* ---- Glow ambiental detrás de la cabecera ---- */
  .gallery-glow {
    position: absolute;
    top: -120px;
    left: 50%;
    width: 620px;
    height: 420px;
    transform: translateX(-50%);
    border-radius: 9999px;
    filter: blur(100px);
    background: radial-gradient(
      circle,
      rgba(120, 113, 108, 0.28),
      transparent 70%
    );
    animation: breathe 14s ease-in-out infinite alternate;
  }

  @keyframes breathe {
    from {
      transform: translateX(-50%) scale(1);
      opacity: 0.6;
    }
    to {
      transform: translateX(-50%) scale(1.15);
      opacity: 0.9;
    }
  }

  /* ---- Fotos: revelado al entrar en el viewport (scroll) ---- */
  .photo-reveal {
    opacity: 0;
    transform: translateY(24px) scale(0.98);
    transition:
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .photo-reveal.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* ---- Accesibilidad: respeta a quien prefiere menos movimiento ---- */
  @media (prefers-reduced-motion: reduce) {
    .gallery-glow {
      animation: none;
    }
    .photo-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  function initLightbox() {
    const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
    const img = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const closeBtn = document.getElementById('lightbox-close');

    if (!dialog || !img) return;

    document.querySelectorAll<HTMLButtonElement>('[data-lightbox-trigger]').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        img.src = trigger.dataset.large ?? '';
        img.alt = trigger.dataset.alt ?? '';
        dialog.showModal();
      });
    });

    // Cerrar al pulsar el botón, la imagen o el fondo (backdrop).
    closeBtn?.addEventListener('click', () => dialog.close());
    img.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });
    // Limpia el src al cerrar para liberar memoria.
    dialog.addEventListener('close', () => {
      img.src = '';
    });
  }

  function initPhotoReveal() {
    const revealTargets = document.querySelectorAll<HTMLElement>('.photo-reveal');
    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;

    if (prefersReducedMotion || !('IntersectionObserver' in window)) {
      // Sin animación: muestra todo directamente.
      revealTargets.forEach((el) => el.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            obs.unobserve(entry.target); // Una sola vez por foto.
          }
        });
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
    );

    revealTargets.forEach((el) => observer.observe(el));
  }

  // astro:page-load se dispara en la carga inicial y tras cada navegación
  // con View Transitions, por lo que reinicia el lightbox y el revelado
  // sobre el DOM recién intercambiado.
  document.addEventListener('astro:page-load', () => {
    initLightbox();
    initPhotoReveal();
  });
</script>
