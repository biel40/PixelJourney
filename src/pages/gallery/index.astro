---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGalleryPhotos } from '../../lib/gallery';

const photos = await getGalleryPhotos();
---

<BaseLayout
  title="Galería"
  description="Colección de fotografías móviles capturadas en el día a día."
>
  <main class="mx-auto max-w-6xl px-6 py-16">
    <header class="mb-12 text-center">
      <p class="text-xs font-mono tracking-[0.3em] uppercase text-neutral-500">
        Galería
      </p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight text-white">
        Momentos
      </h1>
      <p class="mt-3 text-sm text-neutral-400">
        {photos.length} fotografías
      </p>
    </header>

    {
      photos.length === 0 ? (
        <p class="text-center text-neutral-500">
          Aún no hay fotografías disponibles.
        </p>
      ) : (
        <div class="columns-1 gap-4 sm:columns-2 lg:columns-3 *:mb-4">
          {photos.map((photo, index) => (
            <figure class="group relative overflow-hidden rounded-lg break-inside-avoid">
              <Image
                src={photo.src}
                alt={photo.alt}
                widths={[320, 640, 960]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                loading={index < 6 ? 'eager' : 'lazy'}
                decoding="async"
                class="w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
              />
            </figure>
          ))}
        </div>
      )
    }
  </main>
</BaseLayout>
