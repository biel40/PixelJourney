# Variables de entorno requeridas — copia este archivo como .env y completa los valores

# Supabase — Panel: Settings > API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # Solo servidor, NUNCA al cliente

# URL canónica del sitio (sin barra final)
PUBLIC_SITE_URL=https://pixeljourney.vercel.app
